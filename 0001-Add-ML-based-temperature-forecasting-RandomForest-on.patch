@@ -145,6 +147,25 @@ async function search(){
     const aqiLabels={1:'Good',2:'Fair',3:'Moderate',4:'Poor',5:'Very Poor'};
     const c=aqi.components||{};
     document.getElementById('aqi-result').innerHTML=`<div class="card"><div class="section-title">Air Quality — ${d.name}</div><div class="aqi-badge aqi-${aqi.aqi}">${aqi.aqi}</div><div style="color:var(--muted);margin-bottom:1rem">${aqiLabels[aqi.aqi]||'Unknown'}</div><div class="stats-grid"><div class="stat"><div class="stat-label">PM2.5</div><div class="stat-value">${c.pm2_5?.toFixed(1)??'—'}</div></div><div class="stat"><div class="stat-label">PM10</div><div class="stat-value">${c.pm10?.toFixed(1)??'—'}</div></div><div class="stat"><div class="stat-label">O3</div><div class="stat-value">${c.o3?.toFixed(1)??'—'}</div></div><div class="stat"><div class="stat-label">NO2</div><div class="stat-value">${c.no2?.toFixed(1)??'—'}</div></div><div class="stat"><div class="stat-label">SO2</div><div class="stat-value">${c.so2?.toFixed(1)??'—'}</div></div><div class="stat"><div class="stat-label">CO</div><div class="stat-value">${c.co?.toFixed(1)??'—'}</div></div></div></div>`;
+    try{
+      const ml=await apiFetch(`/weather/${city}/ml-forecast?days=7`);
+      const preds=ml.predictions;
+      const temps=preds.map(p=>p.predicted_temp_max);
+      const min=Math.min(...temps),max=Math.max(...temps);
+      const range=max-min||1;
+      const w=600,h=160,pad=20;
+      const pts=preds.map((p,i)=>{
+        const x=pad+(i/(preds.length-1))*(w-2*pad);
+        const y=h-pad-((p.predicted_temp_max-min)/range)*(h-2*pad);
+        return `${x},${y}`;
+      }).join(' ');
+      const dots=preds.map((p,i)=>{
+        const x=pad+(i/(preds.length-1))*(w-2*pad);
+        const y=h-pad-((p.predicted_temp_max-min)/range)*(h-2*pad);
+        return `<circle cx="${x}" cy="${y}" r="4" fill="var(--accent2)"/><text x="${x}" y="${h-2}" font-size="9" fill="var(--muted)" text-anchor="middle">${new Date(p.date).toLocaleDateString([],{weekday:'short'})}</text><text x="${x}" y="${y-10}" font-size="10" fill="var(--text)" text-anchor="middle">${p.predicted_temp_max}°</text>`;
+      }).join('');
+      document.getElementById('ml-result').innerHTML=`<div class="card"><div class="section-title">7-Day ML Forecast — ${d.name}</div><div style="font-size:0.75rem;color:var(--muted);margin-bottom:1rem">Model: ${ml.model} · trained through ${ml.trained_through}</div><svg viewBox="0 0 ${w} ${h}" style="width:100%;height:auto"><polyline points="${pts}" fill="none" stroke="var(--accent)" stroke-width="2"/>${dots}</svg></div>`;
+    }catch(e){document.getElementById('ml-result').innerHTML=`<div class="error">${e.message}</div>`}
   }catch(e){document.getElementById('current-result').innerHTML=`<div class="error">${e.message}</div>`}
   btn.disabled=false;btn.textContent='Search';loadStatsStrip()
 }
